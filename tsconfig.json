{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node", "hardhat"]
  },
  "include": [
    "hardhat.config.ts",
    "deploy/**/*.ts",
    "test/**/*.ts",
    "tasks/**/*.ts"
  ]
}